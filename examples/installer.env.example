# Example installer environment — PLACEHOLDERS ONLY.
#
# Copy to a local, gitignored file (e.g. installer.env) and resolve at runtime
# with the 1Password CLI, for example:
#
#   op run --env-file ./installer.env -- ./install.sh
#
# Every value is an `op://` REFERENCE — never a real secret. The installer reads
# the actual values from your per-platform 1Password items at runtime. Do NOT
# commit a filled-in copy: *.env is gitignored and CI rejects secret shapes.
#
# One API Credential item PER PLATFORM in your vault — see examples/1password-item.example.md.

# --- identity (Agent item) ---
AGENT_NAME="op://YOUR_VAULT/Agent/name"
SLACK_ALLOWED_USERS="op://YOUR_VAULT/Agent/allowed_user"
SLACK_HOME_CHANNEL="op://YOUR_VAULT/Agent/home_channel"

# --- brain (models); Codex is an interactive login, not a field ---
OPENROUTER_API_KEY="op://YOUR_VAULT/OpenRouter/credential"
OPENAI_API_KEY="op://YOUR_VAULT/OpenAI/credential"

# --- Slack app (the agent's only channel at V1) ---
SLACK_BOT_TOKEN="op://YOUR_VAULT/Slack/bot_token"
SLACK_APP_TOKEN="op://YOUR_VAULT/Slack/app_token"
SLACK_SIGNING_SECRET="op://YOUR_VAULT/Slack/signing_secret"

# --- backup (recommended) ---
GITHUB_BACKUP_PAT="op://YOUR_VAULT/GitHub/backup_pat"
GITHUB_BACKUP_REPO="op://YOUR_VAULT/GitHub/backup_repo"

# --- networking (optional) ---
TAILSCALE_AUTHKEY="op://YOUR_VAULT/Tailscale/credential"

# Codex login is interactive at install time — not provided via this file.
